<% layout("/layouts/boilerplate") %>

<style>
  /* Make sure boilerplate doesn't interfere */
  main {
    padding: 0;
    margin: 0;
  }
</style>

<!-- STICKY PREMIUM NAVBAR -->
<nav class="premium-navbar">
  <div class="navbar-container">
    <!-- Logo -->
    <a href="/" class="navbar-logo">
      <i class="fa-solid fa-compass"></i> WanderLust
    </a>

    <!-- Search Bar -->
    <div class="navbar-search-wrapper">
      <div class="navbar-search">
        <i class="fa-solid fa-magnifying-glass navbar-search-icon"></i>
        <input type="text" id="navbar-search-input" placeholder="Search destinations...">
      </div>
    </div>

    <!-- Action Icons -->
    <div class="navbar-actions">
      <!-- Wishlist -->
      <button class="navbar-icon-btn wishlist" id="wishlist-btn" title="Wishlist">
        <i class="fa-regular fa-heart"></i>
        <span class="badge" id="wishlist-count">0</span>
      </button>

      <!-- Profile/Login -->
      <% if(currUser) { %>
        <div class="navbar-profile">
          <div class="navbar-avatar"><%= currUser.username.charAt(0).toUpperCase() %></div>
          <span style="font-size: 0.9rem; color: var(--text-secondary);">
            <%= currUser.username %>
          </span>
        </div>
      <% } else { %>
        <a href="/login" class="navbar-icon-btn" title="Sign In">
          <i class="fa-solid fa-user"></i>
        </a>
      <% } %>
    </div>
  </div>
</nav>

<!-- MAIN CONTENT -->
<div class="listings-page">
  <!-- FILTER SIDEBAR -->
  <aside class="filter-sidebar" id="filter-sidebar">
    <!-- Price Range Filter -->
    <div class="filter-card">
      <div class="filter-title">
        <i class="fa-solid fa-indian-rupee-sign"></i> Price Range
      </div>
      <div class="price-range-wrapper">
        <div class="price-inputs">
          <input type="number" class="price-input" placeholder="Min" id="min-price" value="0">
          <span style="color: var(--text-secondary);">–</span>
          <input type="number" class="price-input" placeholder="Max" id="max-price" value="50000">
        </div>
        <input type="range" id="price-range" min="0" max="50000" value="50000">
      </div>
    </div>

    <!-- Star Rating Filter -->
    <div class="filter-card">
      <div class="filter-title">
        <i class="fa-solid fa-star"></i> Rating
      </div>
      <div class="star-rating-filter">
        <label class="star-option">
          <input type="radio" name="rating" value="all" checked>
          <span label="label">All Ratings</span>
        </label>
        <label class="star-option">
          <input type="radio" name="rating" value="5">
          <span class="stars">★★★★★</span>
          <span label="label">(5 stars)</span>
        </label>
        <label class="star-option">
          <input type="radio" name="rating" value="4">
          <span class="stars">★★★★☆</span>
          <span label="label">(4+ stars)</span>
        </label>
        <label class="star-option">
          <input type="radio" name="rating" value="3">
          <span class="stars">★★★☆☆</span>
          <span label="label">(3+ stars)</span>
        </label>
      </div>
    </div>

    <!-- Amenities Filter -->
    <div class="filter-card">
      <div class="filter-title">
        <i class="fa-solid fa-sparkles"></i> Amenities
      </div>
      <div class="checkbox-group">
        <label class="checkbox-item">
          <input type="checkbox" class="amenity-filter" value="WiFi">
          <label>WiFi</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="amenity-filter" value="Pool">
          <label>Swimming Pool</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="amenity-filter" value="AC">
          <label>Air Conditioning</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="amenity-filter" value="Breakfast">
          <label>Free Breakfast</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="amenity-filter" value="Parking">
          <label>Free Parking</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="amenity-filter" value="Gym">
          <label>Fitness Center</label>
        </label>
      </div>
    </div>

    <!-- Property Type Filter -->
    <div class="filter-card">
      <div class="filter-title">
        <i class="fa-solid fa-building"></i> Property Type
      </div>
      <div class="checkbox-group">
        <label class="checkbox-item">
          <input type="checkbox" class="type-filter" value="Hotel">
          <label>Hotel</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="type-filter" value="Villa">
          <label>Villa</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="type-filter" value="Resort">
          <label>Resort</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="type-filter" value="Apartment">
          <label>Apartment</label>
        </label>
        <label class="checkbox-item">
          <input type="checkbox" class="type-filter" value="Cottage">
          <label>Cottage</label>
        </label>
      </div>
    </div>

    <!-- Reset Button -->
    <button class="reset-filters-btn" id="reset-filters">Reset All Filters</button>
  </aside>

  <!-- CONTENT AREA -->
  <div class="listings-content">
    <!-- SORT BAR -->
    <div class="sort-bar">
      <div class="results-info">
        Showing <strong id="results-count"><%= allListings.length %></strong> results
      </div>
      <div class="sort-controls">
        <select class="sort-dropdown" id="sort-select">
          <option value="relevance">Sort by: Relevance</option>
          <option value="price-low">Price: Low to High</option>
          <option value="price-high">Price: High to Low</option>
          <option value="rating">Highest Rated</option>
          <option value="newest">Newest First</option>
        </select>
        <div class="view-toggle-group">
          <button class="view-toggle-btn active" id="grid-view" title="Grid View">
            <i class="fa-solid fa-grip"></i>
          </button>
          <button class="view-toggle-btn" id="list-view" title="List View">
            <i class="fa-solid fa-list"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- GRID VIEW - HOTEL CARDS -->
    <div class="listings-grid" id="listings-grid">
      <% if(allListings.length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="fa-solid fa-search"></i>
          </div>
          <h3 class="empty-state-title">No properties found</h3>
          <p>Try adjusting your filters or search criteria</p>
        </div>
      <% } %>

      <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="hotel-card" data-price="<%= listing.price %>">
          <!-- Image Section -->
          <div class="hotel-image-wrapper">
            <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="hotel-image">
            
            <!-- Badge -->
            <div class="hotel-badge">
              <i class="fa-solid fa-star"></i> Featured
            </div>

            <!-- Carousel Dots -->
            <div class="carousel-dots">
              <span class="dot active"></span>
              <span class="dot"></span>
              <span class="dot"></span>
            </div>
          </div>

          <!-- Hotel Info -->
          <div class="hotel-info">
            <!-- Header with Title & Wishlist -->
            <div class="hotel-header">
              <h3 class="hotel-title"><%= listing.title %></h3>
              <button class="hotel-wishlist" data-id="<%= listing._id %>">
                <i class="fa-regular fa-heart"></i>
              </button>
            </div>

            <!-- Location -->
            <div class="hotel-location">
              <i class="fa-solid fa-location-dot"></i>
              <span><%= listing.location %></span>
            </div>

            <!-- Rating -->
            <div class="hotel-rating">
              <div class="stars-display">
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-regular fa-star"></i>
              </div>
              <span class="rating-text">4.0</span>
              <span class="review-count">(324 reviews)</span>
            </div>

            <!-- Amenities (if available in your data) -->
            <div class="hotel-amenities">
              <div class="amenity-icon" title="WiFi">
                <i class="fa-solid fa-wifi"></i>
              </div>
              <div class="amenity-icon" title="Pool">
                <i class="fa-solid fa-water"></i>
              </div>
              <div class="amenity-icon" title="AC">
                <i class="fa-solid fa-fan"></i>
              </div>
              <div class="amenity-icon" title="Parking">
                <i class="fa-solid fa-square-parking"></i>
              </div>
            </div>

            <!-- Price Section -->
            <div class="hotel-price-section">
              <div class="hotel-price">
                <span class="price-currency">₹</span>
                <span class="price-amount"><%= listing.price.toLocaleString("en-IN") %></span>
                <span class="price-per-night">/ night</span>
              </div>
              <button class="view-details-btn">View Details</button>
            </div>
          </div>
        </a>
      <% } %>
    </div>

    <!-- LIST VIEW - HOTEL CARDS (Hidden by default) -->
    <div class="listings-list" id="listings-list" style="display: none;">
      <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="hotel-card-list" data-price="<%= listing.price %>">
          <!-- Image -->
          <div class="hotel-image-wrapper">
            <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="hotel-image">
          </div>

          <!-- Info -->
          <div class="hotel-info">
            <div class="hotel-header">
              <h3 class="hotel-title"><%= listing.title %></h3>
              <button class="hotel-wishlist" data-id="<%= listing._id %>">
                <i class="fa-regular fa-heart"></i>
              </button>
            </div>

            <div class="hotel-location">
              <i class="fa-solid fa-location-dot"></i>
              <span><%= listing.location %></span>
            </div>

            <div class="hotel-rating">
              <div class="stars-display">
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-regular fa-star"></i>
              </div>
              <span class="review-count">(324 reviews)</span>
            </div>

            <p style="color: var(--text-secondary); margin: 0.5rem 0;">
              <%= listing.description || 'Luxurious property with modern amenities and exceptional service.' %>
            </p>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto;">
              <div class="hotel-price">
                <span class="price-currency">₹</span>
                <span class="price-amount"><%= listing.price.toLocaleString("en-IN") %></span>
                <span class="price-per-night">/ night</span>
              </div>
              <button class="view-details-btn">View Details</button>
            </div>
          </div>
        </a>
      <% } %>
    </div>

    <!-- PAGINATION -->
    <div class="pagination-wrapper">
      <div class="pagination">
        <button class="pagination-btn" id="prev-btn">
          <i class="fa-solid fa-chevron-left"></i>
        </button>
        <button class="pagination-btn active" data-page="1">1</button>
        <button class="pagination-btn" data-page="2">2</button>
        <button class="pagination-btn" data-page="3">3</button>
        <span style="padding: 0 0.75rem; display: flex; align-items: center; color: var(--text-secondary);">...</span>
        <button class="pagination-btn" data-page="10">10</button>
        <button class="pagination-btn" id="next-btn">
          <i class="fa-solid fa-chevron-right"></i>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- LINK PREMIUM CSS -->
<link rel="stylesheet" href="/css/premium-listings.css">

<script>
// ============================================
// PREMIUM LISTINGS INTERACTIVITY
// ============================================

// 1. View Toggle (Grid/List)
const gridViewBtn = document.getElementById('grid-view');
const listViewBtn = document.getElementById('list-view');
const listingsGrid = document.getElementById('listings-grid');
const listingsList = document.getElementById('listings-list');

gridViewBtn.addEventListener('click', () => {
  gridViewBtn.classList.add('active');
  listViewBtn.classList.remove('active');
  listingsGrid.style.display = 'grid';
  listingsList.style.display = 'none';
});

listViewBtn.addEventListener('click', () => {
  listViewBtn.classList.add('active');
  gridViewBtn.classList.remove('active');
  listingsGrid.style.display = 'none';
  listingsList.style.display = 'flex';
});

// 2. Sorting
const sortSelect = document.getElementById('sort-select');
const allListings = document.querySelectorAll('[data-price]');

sortSelect.addEventListener('change', function() {
  const cards = Array.from(allListings);
  
  switch(this.value) {
    case 'price-low':
      cards.sort((a, b) => parseInt(a.dataset.price) - parseInt(b.dataset.price));
      break;
    case 'price-high':
      cards.sort((a, b) => parseInt(b.dataset.price) - parseInt(a.dataset.price));
      break;
    case 'rating':
      cards.sort((a, b) => Math.random() - 0.5); // Placeholder
      break;
    default:
      // Keep original order
      break;
  }
  
  // Re-append sorted cards
  cards.forEach(card => {
    listingsGrid.appendChild(card.cloneNode(true));
    listingsList.appendChild(card.cloneNode(true));
  });
});

// 3. Wishlist Functionality
const wishlistBtns = document.querySelectorAll('.hotel-wishlist');
let wishlistedItems = JSON.parse(localStorage.getItem('wishlist')) || [];

wishlistBtns.forEach(btn => {
  const listingId = btn.dataset.id;
  
  // Check if already wishlisted
  if(wishlistedItems.includes(listingId)) {
    btn.classList.add('liked');
    btn.innerHTML = '<i class="fa-solid fa-heart"></i>';
  }
  
  btn.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    
    btn.classList.toggle('liked');
    
    if(wishlistedItems.includes(listingId)) {
      wishlistedItems = wishlistedItems.filter(id => id !== listingId);
    } else {
      wishlistedItems.push(listingId);
    }
    
    localStorage.setItem('wishlist', JSON.stringify(wishlistedItems));
    updateWishlistCount();
  });
});

function updateWishlistCount() {
  const count = JSON.parse(localStorage.getItem('wishlist')) || [];
  document.getElementById('wishlist-count').textContent = count.length;
}

// Initial count
updateWishlistCount();

// 4. Price Range Filter
const maxPriceInput = document.getElementById('max-price');
const priceRange = document.getElementById('price-range');
const minPriceInput = document.getElementById('min-price');

priceRange.addEventListener('input', (e) => {
  maxPriceInput.value = e.target.value;
  filterListings();
});

maxPriceInput.addEventListener('change', (e) => {
  priceRange.value = e.target.value;
  filterListings();
});

function filterListings() {
  const maxPrice = parseInt(maxPriceInput.value);
  const minPrice = parseInt(minPriceInput.value);
  
  allListings.forEach(card => {
    const price = parseInt(card.dataset.price);
    if(price >= minPrice && price <= maxPrice) {
      card.style.display = '';
    } else {
      card.style.display = 'none';
    }
  });
}

// 5. Reset Filters
document.getElementById('reset-filters').addEventListener('click', () => {
  document.getElementById('min-price').value = 0;
  document.getElementById('max-price').value = 50000;
  document.getElementById('price-range').value = 50000;
  document.querySelectorAll('.amenity-filter, .type-filter').forEach(input => {
    input.checked = false;
  });
  document.querySelector('input[name="rating"][value="all"]').checked = true;
  filterListings();
});

// 6. Pagination (Basic)
document.querySelectorAll('.pagination-btn[data-page]').forEach(btn => {
  btn.addEventListener('click', (e) => {
    document.querySelectorAll('.pagination-btn.active').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
  });
});

// 7. Carousel Dots Animation
document.querySelectorAll('.carousel-dots').forEach(dotContainer => {
  let currentDot = 0;
  const dots = dotContainer.querySelectorAll('.dot');
  
  setInterval(() => {
    dots[currentDot].classList.remove('active');
    currentDot = (currentDot + 1) % dots.length;
    dots[currentDot].classList.add('active');
  }, 3000);
});

// 8. Search Bar
document.getElementById('navbar-search-input').addEventListener('input', (e) => {
  const searchTerm = e.target.value.toLowerCase();
  allListings.forEach(card => {
    const title = card.querySelector('.hotel-title').textContent.toLowerCase();
    const location = card.querySelector('.hotel-location').textContent.toLowerCase();
    
    if(title.includes(searchTerm) || location.includes(searchTerm)) {
      card.style.display = '';
    } else {
      card.style.display = 'none';
    }
  });
});

// 9. Tax Info Toggle (from original)
let taxSwitch = document.querySelector('.tax-toggle input');
if(taxSwitch) {
  taxSwitch.addEventListener('click', () => {
    let taxInfo = document.getElementsByClassName('tax-info');
    for(let info of taxInfo) {
      if(info.style.display != 'inline') {
        info.style.display = 'inline';
      } else {
        info.style.display = 'none';
      }
    }
  });
}
</script>
